{
  "name": "@technofest/web",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "clean:next": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "validate:privacy": "node scripts/validate-privacy.mjs",
    "demo:seed-auth": "node scripts/seed-demo-auth-users.mjs",
    "supabase:start": "node scripts/run-with-app-env.mjs supabase --workdir ../supabase start",
    "supabase:stop": "node scripts/run-with-app-env.mjs supabase --workdir ../supabase stop",
    "supabase:status": "node scripts/run-with-app-env.mjs supabase --workdir ../supabase status",
    "supabase:reset": "node scripts/run-with-app-env.mjs supabase --workdir ../supabase db reset --local",
    "supabase:test": "node scripts/run-with-app-env.mjs supabase --workdir ../supabase test db",
    "supabase:advisors": "node scripts/run-with-app-env.mjs supabase --workdir ../supabase db advisors --local --type all --fail-on warn"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "ai": "^6.0.182",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.49.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "hardhat": "^3.4.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "packageExtensions": {
      "eslint-config-next@*": {
        "peerDependencies": {
          "next": "*"
        }
      }
    }
  }
}
