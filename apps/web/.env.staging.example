# Staging values. Do not commit a filled copy.
# Configure the same values in GitHub Environment "staging" and Vercel Preview vars scoped to branch "development".
NEXT_PUBLIC_APP_URL=https://staging.medproof.binerlabs.com
NEXT_PUBLIC_SUPABASE_URL=https://<staging-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
ADMIN_EMAIL_ALLOWLIST=
ENCRYPTION_MASTER_KEY=
HASH_PEPPER=

# Staging Google OAuth client.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=MedProof <noreply@staging.medproof.binerlabs.com>

DEEPSEEK_API_KEY=
AMOY_RPC_URL=
RELAYER_PRIVATE_KEY=
MEDPROOF_CONTRACT_ADDRESS=
NEXT_PUBLIC_MEDPROOF_CONTRACT_ADDRESS=

# Optional remote privacy validation sentinel list.
MEDPROOF_PRIVACY_SENTINELS=
